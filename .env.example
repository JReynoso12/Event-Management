# PostgreSQL connection (required when NEXT_PUBLIC_USE_DATABASE=true)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventflow

# Min 16 chars — used to sign session cookies (required with database mode)
SESSION_SECRET=change-this-to-a-long-random-string

# Set to "true" in .env.local so the UI uses PostgreSQL + server actions
NEXT_PUBLIC_USE_DATABASE=true
